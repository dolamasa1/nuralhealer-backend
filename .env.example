# Database
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Secret (CHANGE THIS IN PRODUCTION - must be at least 256 bits)
JWT_SECRET=your-super-secret-key-min-256-bits-change-this-in-production-environment

# Spring Profile
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
JWT_EXPIRATION=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173
