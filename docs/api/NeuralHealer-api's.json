        },
        {
          "type": "http",
          "name": "Find User by Email",
          "filename": "FindUserByEmail.bru",
          "seq": 2,
          "request": {
            "url": "http://localhost:8080/api/users/by-email?email=patient@test.com",
            "method": "GET",
            "docs": "Lookup a user's basic info and role by their email address."
          }
        }
      ]
    },
    {
      "type": "folder",
