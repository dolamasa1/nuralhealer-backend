            "docs": "List all available doctor profiles in the system."
          }
        }
      ]
    },
    {
      "type": "folder",
      "name": "4. Engagement System",
      "filename": "Engagement System",
      "seq": 4,
      "items": [
        {
          "type": "http",
          "name": "1. Initiate Engagement (Doctor)",
          "filename": "Initiate Engagement (Doctor).bru",
          "seq": 1,
          "request": {
            "url": "http://localhost:8080/api/engagements/initiate",
            "method": "POST",
            "body": {
              "mode": "json",
              "json": "{\n  \"patientId\": \"{{patient_id}}\",\n  \"accessRuleName\": \"FULL_ACCESS\"\n}"
            },
            "docs": "Doctor creates a pending engagement."
          }
        },
        {
          "type": "http",
          "name": "2. Get Current Token (Doctor)",
          "filename": "GetToken.bru",
          "seq": 2,
          "request": {
            "url": "http://localhost:8080/api/engagements/{{engagement_id}}/token",
            "method": "GET",
            "docs": "Retrieve valid START token."
          }
        },
        {
          "type": "http",
          "name": "3. Refresh Token (Doctor)",
          "filename": "RefreshToken.bru",
          "seq": 3,
          "request": {
            "url": "http://localhost:8080/api/engagements/{{engagement_id}}/refresh-token",
            "method": "POST"
          }
        },
        {
          "type": "http",
          "name": "4. Verify & Start (Patient)",
          "filename": "VerifyStart.bru",
          "seq": 4,
          "request": {
            "url": "http://localhost:8080/api/engagements/verify-start",
            "method": "POST",
            "body": {
              "mode": "json",
              "json": "{\"token\": \"NH-XXXXXX\"}"
            }
          }
        },
        {
          "type": "http",
          "name": "5. List My Engagements",
          "filename": "List Engagements.bru",
          "seq": 5,
          "request": {
            "url": "http://localhost:8080/api/engagements/my-engagements",
            "method": "GET"
          }
        },
        {
          "type": "folder",
          "name": "Messaging",
          "filename": "Messaging",
          "seq": 6,
          "items": [
            {
              "type": "http",
              "name": "Get Messages",
              "filename": "GetMessages.bru",
              "seq": 1,
              "request": {
                "url": "http://localhost:8080/api/engagements/{{engagement_id}}/messages",
                "method": "GET"
              }
            },
            {
              "type": "http",
              "name": "Send Message",
              "filename": "SendMessage.bru",
              "seq": 2,
              "request": {
                "url": "http://localhost:8080/api/engagements/{{engagement_id}}/messages",
                "method": "POST",
                "body": {
                  "mode": "json",
                  "json": "{\"content\": \"Hello!\"}"
                }
              }
            }
          ]
        },
        {
          "type": "folder",
          "name": "Termination",
          "filename": "Termination",
          "seq": 7,
          "items": [
            {
              "type": "http",
              "name": "Cancel (Doctor)",
              "filename": "CancelDoctor.bru",
              "seq": 1,
              "request": {
                "url": "http://localhost:8080/api/engagements/{{engagement_id}}/cancel",
                "method": "POST",
                "body": {
                  "mode": "json",
                  "json": "{\"reason\": \"Schedule conflict\"}"
                }
              }
            },
            {
              "type": "http",
              "name": "Cancel (Patient)",
              "filename": "CancelPatient.bru",
              "seq": 2,
              "request": {
                "url": "http://localhost:8080/api/engagements/{{engagement_id}}/cancel",
                "method": "POST",
                "body": {
                  "mode": "json",
                  "json": "{\n  \"reason\": \"Switching doctors\",\n  \"newAccessRule\": \"READ_ONLY_ACCESS\"\n}"
                }
              }
            },
            {
              "type": "http",
              "name": "Hard Delete (Cleanup)",
              "filename": "HardDelete.bru",
              "seq": 3,
              "request": {
                "url": "http://localhost:8080/api/engagements/{{engagement_id}}",
                "method": "DELETE"
              }
            }
          ]
        }
