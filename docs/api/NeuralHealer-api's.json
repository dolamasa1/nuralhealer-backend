      "filename": "User Management",
      "seq": 2,
      "items": [
        {
          "type": "http",
          "name": "Get Current User (Me)",
          "filename": "GetCurrentUser.bru",
          "seq": 1,
          "request": {
            "url": "http://localhost:8080/api/users/me",
            "method": "GET"
